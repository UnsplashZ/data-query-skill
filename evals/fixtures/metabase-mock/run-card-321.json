{
  "card": {
    "id": 321,
    "name": "Refund Daily KPI Mock",
    "parameters": [
      {
        "id": "start_date",
        "name": "start_date",
        "type": "date/single",
        "required": true
      },
      {
        "id": "end_date",
        "name": "end_date",
        "type": "date/single",
        "required": true
      }
    ],
    "dataset_query": {
      "database": 7,
      "type": "native",
      "native": {
        "query": "SELECT toDate(refund_created_at) AS refund_date, sku_name, sum(refund_amount) AS refund_amount FROM analytics.refund_order_daily WHERE refund_created_at >= toDate({{start_date}}) AND refund_created_at < toDate({{end_date}}) GROUP BY refund_date, sku_name LIMIT 100",
        "template-tags": {
          "start_date": {
            "name": "start_date",
            "type": "date",
            "required": true
          },
          "end_date": {
            "name": "end_date",
            "type": "date",
            "required": true
          }
        }
      }
    }
  },
  "query_result": [
    {
      "refund_date": "2026-05-01",
      "sku_name": "demo-sku-a",
      "refund_amount": 1200.5
    },
    {
      "refund_date": "2026-05-02",
      "sku_name": "demo-sku-b",
      "refund_amount": 880.0
    }
  ]
}
